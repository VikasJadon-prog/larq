aazh0"><h3 class="headingTitle"><span class="headingTitle_prefix">1</span><span>Fill up anywhere</span></h3></div></div><div class="cardBody_text">The LARQ Bottle PureVis™ gives you the power to take brilliantly clean water with you everywhere you go.</div></div></div></div><div class="css-a4lnj2"><div class="css-1rbqkfv exvjhuk0"><div class="cardHead"><img src="./bottle12_files/LARQ_Press-The-Button-Cup_2x.jpg" alt="Larq purevis™ bottle funcationality, Tap - normal mode, Double tap - Adventure mode" decoding="async" loading="lazy"></div><div class="cardBody"><div class="cardBody_title"><div class="css-16gxt67 eb9aazh0"><h3 class="headingTitle"><span class="headingTitle_prefix">2</span><span>Press the cap for PureVis™</span></h3></div></div><div class="cardBody_text">While you wait, give the bottle a gentle shake or do your best water dance to spread the PureVis™ light evenly.</div><div class="cardBody_children"><div class="css-jawvkk e1ge1dkw0"><div class="tapInstruction"><span class="tapInstruction_dots"></span><span class="tapInstruction_title">Tap</span><span class="tapInstruction_note">Normal Mode</span></div><div class="tapInstruction"><span class="tapInstruction_dots double"></span><span class="tapInstruction_title">Double Tap</span><span class="tapInstruction_note">Adventure-mode</span></div></div></div></div></div></div><div class="css-a4lnj2"><div class="css-1rbqkfv exvjhuk0"><div class="cardHead"><img src="./bottle12_files/LARQ_Drink-Clean_2x.jpg" alt="Larq purevis™ bottle being in use" decoding="async" loading="lazy"></div><div class="cardBody"><div class="cardBody_title"><div class="css-16gxt67 eb9aazh0"><h3 class="headingTitle"><span class="headingTitle_prefix">3</span><span>And voila!</span></h3></div></div><div class="cardBody_text">Enjoy brilliantly clean water from a clean bottle. It's that simple.</div></div></div></div></div></div></div></div><div class="css-bgf5c2 e4b8vos0"><div class="css-5cev5b"><div class="css-gp474v"><div class="css-l3rx45"><div class="css-1g231j7"><div class="css-1d0ax0j eb9aazh0"><h2 class="headingTitle">Technical specifications</h2></div></div><div class="css-tlwo8p"><div class="css-1pl443f e10iog5i0"><div class="specificationsBlock_image"><div class="specificationsBlock_imageInner"><img src="./bottle12_files/DW.png" alt="Photo of LARQ Bottle PureVis™ Insulated regular and large size in Monaco Blue color" decoding="async" loading="lazy"></div></div><div class="specificationsBlock_listing"><div class="css-1q5z0e ej3v5vx0"><div class="specificationsListing_body"><div class="specificationsListing_item css-1uqqybm e78h3140"><div class="specificationItem_inner"><div class="specificationItem_label">Volume</div><div class="specificationItem_value"><i class="specificationItem_chevron" aria-hidden="true"><span color="text.default" class="css-11qxqh7 e1evajc90"><svg class="css-82n8sf eks92ln0" focusable="false" viewBox="0 0 13 22" color="text.default" aria-hidden="true"><path d="M1.294.736l-.328.328a.54.54 0 000 .797l9.14 9.14-9.14 9.188a.54.54 0 000 .797l.328.328a.54.54 0 00.797 0l9.89-9.89a.54.54 0 000-.797L2.091.736a.54.54 0 00-.797 0z" fill="#F3756D"></path></svg></span></i><span>17 oz / 25 oz</span></div></div></div><div class="specificationsListing_item css-1uqqybm e78h3140"><div class="specificationItem_inner"><div class="specificationItem_label">Technology</div><div class="specificationItem_value"><i class="specificationItem_chevron" aria-hidden="true"><span color="text.default" class="css-11qxqh7 e1evajc90"><svg class="css-82n8sf eks92ln0" focusable="false" viewBox="0 0 13 22" color="text.default" aria-hidden="true"><path d="M1.294.736l-.328.328a.54.54 0 000 .797l9.14 9.14-9.14 9.188a.54.54 0 000 .797l.328.328a.54.54 0 00.797 0l9.89-9.89a.54.54 0 000-.797L2.091.736a.54.54 0 00-.797 0z" fill="#F3756D"></path></svg></span></i><span>PureVis™</span></div></div></div><div class="specificationsListing_item css-1uqqybm e78h3140"><div class="specificationItem_inner"><div class="specificationItem_label">Weight</div><div class="specificationItem_value"><i class="specificationItem_chevron" aria-hidden="true"><span color="text.default" class="css-11qxqh7 e1evajc90"><svg class="css-82n8sf eks92ln0" focusable="false" viewBox="0 0 13 22" color="text.default" aria-hidden="true"><path d="M1.294.736l-.328.328a.54.54 0 000 .797l9.14 9.14-9.14 9.188a.54.54 0 000 .797l.328.328a.54.54 0 00.797 0l9.89-9.89a.54.54 0 000-.797L2.091.736a.54.54 0 00-.797 0z" fill="#F3756D"></path></svg></span></i><span>13.5 oz / 17 oz</span></div></div></div><div class="specificationsListing_item css-1uqqybm e78h3140"><div class="specificationItem_inner"><div class="specificationItem_label">Charge time</div><div class="specificationItem_value"><i class="specificationItem_chevron" aria-hidden="true"><span color="text.default" class="css-11qxqh7 e1evajc90"><svg class="css-82n8sf eks92ln0" focusable="false" viewBox="0 0 13 22" color="text.default" aria-hidden="true"><path d="M1.294.736l-.328.328a.54.54 0 000 .797l9.14 9.14-9.14 9.188a.54.54 0 000 .797l.328.328a.54.54 0 00.797 0l9.89-9.89a.54.54 0 000-.797L2.091.736a.54.54 0 00-.797 0z" fill="#F3756D"></path></svg></span></i><span>1 hour</span></div></div></div><div class="specificationsListing_item css-1uqqybm e78h3140"><div class="specificationItem_inner"><div class="specificationItem_label">Height</div><div class="specificationItem_value"><i class="specificationItem_chevron" aria-hidden="true"><span color="text.default" class="css-11qxqh7 e1evajc90"><svg class="css-82n8sf eks92ln0" focusable="false" viewBox="0 0 13 22" color="text.default" aria-hidden="true"><path d="M1.294.736l-.328.328a.54.54 0 000 .797l9.14 9.14-9.14 9.188a.54.54 0 000 .797l.328.328a.54.54 0 00.797 0l9.89-9.89a.54.54 0 000-.797L2.091.736a.54.54 0 00-.797 0z" fill="#F3756D"></path></svg></span></i><span>9.6" / 10.4"</span></div></div></div><div class="specificationsListing_item css-1uqqybm e78h3140"><div class="specificationItem_inner"><div class="specificationItem_label">Run time</div><div class="specificationItem_value"><i class="specificationItem_chevron" aria-hidden="true"><span color="text.default" class="css-11qxqh7 e1evajc90"><svg class="css-82n8sf eks92ln0" focusable="false" viewBox="0 0 13 22" color="text.default" aria-hidden="true"><path d="M1.294.736l-.328.328a.54.54 0 000 .797l9.14 9.14-9.14 9.188a.54.54 0 000 .797l.328.328a.54.54 0 00.797 0l9.89-9.89a.54.54 0 000-.797L2.091.736a.54.54 0 00-.797 0z" fill="#F3756D"></path></svg></span></i><span>Up to a month</span></div></div></div><div class="specificationsListing_item css-1uqqybm e78h3140"><div class="specificationItem_inner"><div class="specificationItem_label">Diameter</div><div class="specificationItem_value"><i class="specificationItem_chevron" aria-hidden="true"><span color="text.default" class="css-11qxqh7 e1evajc90"><svg class="css-82n8sf eks92ln0" focusable="false" viewBox="0 0 13 22" color="text.default" aria-hidden="true"><path d="M1.294.736l-.328.328a.54.54 0 000 .797l9.14 9.14-9.14 9.188a.54.54 0 000 .797l.328.328a.54.54 0 00.797 0l9.89-9.89a.54.54 0 000-.797L2.091.736a.54.54 0 00-.797 0z" fill="#F3756D"></path></svg></span></i><span>2.7" / 3"</span></div></div></div><div class="specificationsListing_item css-1uqqybm e78h3140"><div class="specificationItem_inner"><div class="specificationItem_label">Build</div><div class="specificationItem_value"><i class="specificationItem_chevron" aria-hidden="true"><span color="text.default" class="css-11qxqh7 e1evajc90"><svg class="css-82n8sf eks92ln0" focusable="false" viewBox="0 0 13 22" color="text.default" aria-hidden="true"><path d="M1.294.736l-.328.328a.54.54 0 000 .797l9.14 9.14-9.14 9.188a.54.54 0 000 .797l.328.328a.54.54 0 00.797 0l9.89-9.89a.54.54 0 000-.797L2.091.736a.54.54 0 00-.797 0z" fill="#F3756D"></path></svg></span></i><span>Double wall</span></div><div class="specificationItem_note">up to 24hr* cold</div></div></div></div></div></div></div></div><div class="css-1facsnr"><div class="css-m8gp8c eb9aazh0"><h2 class="headingTitle">In the box</h2></div></div><div class="css-16vu25q"><div class="css-15ft7bm ejivw1c0"><div class="specificationsInBox_item css-auc1i6 e78h3140"><div class="specificationItem_inner"><div class="specificationItem_value"><i class="specificationItem_dot" aria-hidden="true"></i><span>LARQ Bottle PureVis™</span></div></div></div><div class="specificationsInBox_item css-auc1i6 e78h3140"><div class="specificationItem_inner"><div class="specificationItem_value"><i class="specificationItem_dot" aria-hidden="true"></i><span>MicroUSB charging cable</span></div></div></div><div class="specificationsInBox_item css-auc1i6 e78h3140"><div class="specificationItem_inner"><div class="specificationItem_value"><i class="specificationItem_dot" aria-hidden="true"></i><span>Quick Start Guide</span></div></div></div></div></div></div></div></div></div><div class="css-38s40v e4b8vos0"><div class="css-do379h"><div class="css-gp474v"><div class="css-zfa9i5"><div class="css-16vu25q"><div class="css-n09xlj eb9aazh0"><h2 class="headingTitle">Hydration never looked (or felt) so good</h2><div class="headingTitle_lead">#DrinkBrilliantly anytime, anywhere.</div></div></div></div><div class="css-l3rx45"><div class="css-16vu25q"><div class="css-unnz6n e1ec7m260"><div class="css-1mdwcwq e1oz5kx80"><div class="imagesGridItem_inner"><img src="./bottle12_files/1.jpg" alt="Photo of LARQ Bottle PureVis™ - Granite White on wooden staircase" decoding="async" loading="lazy"></div></div><div class="css-1351uxz e1oz5kx80"><div class="imagesGridItem_inner"><img src="./bottle12_files/3.jpg" alt="Photo of LARQ Bottle PureVis™ - Monaco Blue in hands" decoding="async" loading="lazy"></div></div><div class="css-1351uxz e1oz5kx80"><div class="imagesGridItem_inner"><img src="./bottle12_files/4.jpg" alt="Photo of LARQ Bottle PureVis™ - Himalayan Pink in water" decoding="async" loading="lazy"></div></div><div class="css-1351uxz e1oz5kx80"><div class="imagesGridItem_inner"><img src="./bottle12_files/13.jpg" alt="Photo of LARQ Bottle PureVis™ - Monaco Blue large and regular size bottle" decoding="async" loading="lazy"></div></div><div class="css-1351uxz e1oz5kx80"><div class="imagesGridItem_inner"><img src="./bottle12_files/7.jpg" alt="Photo of LARQ Bottle PureVis™ - Seaside Mint in hands on staircase" decoding="async" loading="lazy"></div></div><div class="css-1351uxz e1oz5kx80"><div class="imagesGridItem_inner"><img src="./bottle12_files/17.jpg" alt="Photo of man drinking LARQ Bottle PureVis™ - Granite White" decoding="async" loading="lazy"></div></div><div class="css-1351uxz e1oz5kx80"><div class="imagesGridItem_inner"><img src="./bottle12_files/14.jpg" alt="Photo of LARQ Bottle PureVis™ - Obsidian Black on table" decoding="async" loading="lazy"></div></div></div></div></div></div></div></div><div class="css-wjkj77 e6ah0g60"><div class="slideOut_dialog" role="dialog"><div class="slideOut_dialogInner"><button type="button" class="slideOut_dialog_closeBtn" aria-label="close plan info modal" title="Close dialog"><span color="text.default" class="css-11qxqh7 e1evajc90"><svg class="css-82n8sf eks92ln0" focusable="false" viewBox="0 0 42 26" color="text.default" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M28.707.293l12 12L40 13l.707.707-12 12-1.414-1.414L37.586 14H0v-2h37.586L27.293 1.707 28.707.293z" fill="#153A5B"></path></svg></span></button><div class="css-1lcjx4a eem0ch90"><div class="content"><div class="contentInner"><div class="content_head"><h3 class="content_headTitle">Double-wall vacuum insulation</h3></div><div class="content_body"><div class="content_bodyContent"><p>Keeps water cold for up to 24 hours and hot for 12 hours. Powder-coated in two-toned colors, the LARQ Bottle is perfect for the office, a weekend snow trip, and staying hydrated wherever your adventures take you.</p></div><div class="content_bodyFeatures css-13fu61e e1tr28oi0"><div class="featuresSection_listItem"><div class="featuresSection_listItem_icon"><span 